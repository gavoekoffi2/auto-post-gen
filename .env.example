# Frontend (Vite) — these go in .env / .env.local
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ---------------------------------------------------------------------
# Backend secrets — DO NOT put these in .env. Set them in
# Supabase dashboard → Project Settings → Edge Functions → Secrets.
# Listed here as a checklist only.
# ---------------------------------------------------------------------

# AI generation (OpenRouter — OpenAI-compatible API)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
# IMAGE_GENERATION_TIMEOUT_MS=60000
# APP_NAME="Pro Social AI"
# APP_PUBLIC_URL=https://app.example.com

# Web research: works out-of-the-box for free via Google News RSS +
# DuckDuckGo HTML (no key needed). These TWO keys are OPTIONAL upgrades
# that add higher-quality sources alongside the free ones.
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=

# Ayrshare: third-party API that handles ALL social media OAuth flows
# and publishing for you. Free trial 100 posts/month at app.ayrshare.com,
# paid tiers from $49/month. When this key is present, users get a
# "Connexion rapide" button that links every social account in one
# click, and publish-post routes through Ayrshare instead of the
# per-platform OAuth flow we wrote ourselves.
# AYRSHARE_API_KEY=

# Postiz: open-source social scheduling platform (the one shown in the
# reference video). Handles OAuth + publishing for 30+ networks behind a
# single key. When present, users get a "Connexion via Postiz" option and
# publish-post routes through Postiz. Get the key in Postiz →
# Settings → Developers → Public API.
#   POSTIZ_API_KEY   — required to enable Postiz
#   POSTIZ_API_URL   — optional; override for self-hosted, e.g.
#                      https://your-host/public/v1 (default: cloud API)
# POSTIZ_API_KEY=
# POSTIZ_API_URL=https://api.postiz.com/public/v1

# Zernio: social API that connects + publishes to LinkedIn, Facebook and 13
# more networks via one key, with per-user isolation (Zernio "profiles").
# When present, users get a "Connexion via Zernio" option and publish-post
# routes through Zernio. Get the key at https://zernio.com/dashboard/api-keys
# (format sk_ + 64 hex). NEVER commit the real key — set it in Supabase
# Secrets only.
#   ZERNIO_API_KEY   — required to enable Zernio
#   ZERNIO_API_URL   — optional; defaults to https://zernio.com/api/v1
# ZERNIO_API_KEY=
# ZERNIO_API_URL=https://zernio.com/api/v1

# Shared secret between the Supabase Scheduler and the cron-only
# functions (auto-generate-weekly, send-validation-email, publish-post).
# Also used as the OAuth state HMAC secret unless OAUTH_STATE_SECRET is
# set independently.
# CRON_SECRET=
# OAUTH_STATE_SECRET=

# CORS / public URL
# ALLOWED_ORIGINS=https://app.example.com
# APP_BASE_URL=https://app.example.com

# Email (Resend)
# RESEND_API_KEY=
# RESEND_FROM="Pro Social AI <no-reply@example.com>"
# Where the public contact form (send-contact) delivers messages.
# Defaults to the RESEND_FROM address when unset.
# CONTACT_TO=support@example.com

# OAuth — LinkedIn (https://www.linkedin.com/developers/apps)
# OAUTH_LINKEDIN_CLIENT_ID=
# OAUTH_LINKEDIN_CLIENT_SECRET=

# OAuth — Meta / Facebook / Instagram (https://developers.facebook.com/apps)
# OAUTH_META_APP_ID=
# OAUTH_META_APP_SECRET=

# OAuth — Twitter/X (https://developer.twitter.com/en/portal)
# OAUTH_TWITTER_CLIENT_ID=
# OAUTH_TWITTER_CLIENT_SECRET=
