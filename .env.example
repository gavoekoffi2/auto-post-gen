# Frontend (Vite) — these go in .env / .env.local
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ---------------------------------------------------------------------
# Backend secrets — DO NOT put these in .env. Set them in
# Supabase dashboard → Project Settings → Edge Functions → Secrets.
# Listed here as a checklist only.
# ---------------------------------------------------------------------

# AI generation (Lovable AI Gateway)
# LOVABLE_API_KEY=

# Web research (optional but recommended for unique, on-trend content)
# Set ONE of these to enable the "research before writing" step in
# generate-content. Tavily preferred; Brave is the fallback.
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=

# Shared secret between the Supabase Scheduler and the cron-only
# functions (auto-generate-weekly, send-validation-email, publish-post).
# Also used as the OAuth state HMAC secret unless OAUTH_STATE_SECRET is
# set independently.
# CRON_SECRET=
# OAUTH_STATE_SECRET=

# CORS / public URL
# ALLOWED_ORIGINS=https://app.example.com
# APP_BASE_URL=https://app.example.com

# Email (Resend)
# RESEND_API_KEY=
# RESEND_FROM="Pro Social AI <no-reply@example.com>"

# OAuth — LinkedIn (https://www.linkedin.com/developers/apps)
# OAUTH_LINKEDIN_CLIENT_ID=
# OAUTH_LINKEDIN_CLIENT_SECRET=

# OAuth — Meta / Facebook / Instagram (https://developers.facebook.com/apps)
# OAUTH_META_APP_ID=
# OAUTH_META_APP_SECRET=

# OAuth — Twitter/X (https://developer.twitter.com/en/portal)
# OAUTH_TWITTER_CLIENT_ID=
# OAUTH_TWITTER_CLIENT_SECRET=
